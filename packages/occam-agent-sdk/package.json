{
  "name": "@ff-occam/agent-sdk",
  "version": "1.0.0-rc.2",
  "type": "module",
  "description": "TypeScript SDK for FF-Occam MCP — high-level research, transcode, digest, map, extract workflows",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ContextForgeAI/occam.git"
  },
  "bugs": {
    "url": "https://github.com/ContextForgeAI/occam/issues"
  },
  "homepage": "https://github.com/ContextForgeAI/occam",
  "keywords": [
    "mcp",
    "web-extraction",
    "llm",
    "rag",
    "sdk",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./research": {
      "import": "./dist/research.js",
      "types": "./dist/research.d.ts"
    },
    "./transcode": {
      "import": "./dist/transcode.js",
      "types": "./dist/transcode.d.ts"
    },
    "./digest": {
      "import": "./dist/digest.js",
      "types": "./dist/digest.d.ts"
    },
    "./map": {
      "import": "./dist/map.js",
      "types": "./dist/map.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.js",
    "pack": "npm pack --dry-run",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@ff-occam/mcp": "1.0.0-rc.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "@ff-occam/mcp": "file:../occam-mcp"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
