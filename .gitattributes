# Normalize text files to LF in the repo; Windows checkouts may use CRLF locally.
* text=auto eol=lf

*.md text eol=lf
*.cs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.mdc text eol=lf

*.slnx text eol=lf
*.csproj text eol=lf

# Windows-only scripts keep CRLF when needed
*.bat text eol=crlf
*.cmd text eol=crlf
