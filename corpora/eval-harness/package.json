{
  "name": "@ff-occam/eval-harness",
  "version": "0.1.0",
  "description": "Evaluation harness for web extraction MCP servers — Lighthouse for web extraction",
  "type": "module",
  "main": "dist/run.js",
  "types": "dist/run.d.ts",
  "bin": {
    "occam-eval": "dist/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node dist/run.js --help",
    "eval": "node dist/run.js",
    "eval:smoke": "node dist/run.js --corpus=l0-smoke",
    "eval:genome": "node dist/run.js --corpus=l4-genome",
    "eval:rotation": "node dist/run.js --corpus=quality-audit-rotation",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ff-occam",
    "eval",
    "harness",
    "benchmark",
    "mcp",
    "extraction",
    "quality",
    "lighthouse"
  ],
  "author": "FF-Occam Contributors",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ContextForgeAI/occam.git",
    "directory": "corpora/eval-harness"
  },
  "bugs": {
    "url": "https://github.com/ContextForgeAI/occam/issues"
  },
  "homepage": "https://github.com/ContextForgeAI/occam/tree/main/corpora/eval-harness",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}